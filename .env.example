# ==============================================================================
# Cerevia — Environment Variables Template
# Duplicate this file as '.env' or '.env.local' and supply local credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Local Application Configuration
# ------------------------------------------------------------------------------
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 2. Database & Redis Credentials (used by Docker Compose & local connection)
# ------------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgrespassword
DB_NAME=cerevia
DB_PORT=5432
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 3. Connection URLs
# ------------------------------------------------------------------------------
# For local development outside of Docker:
# DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/cerevia?schema=public"
# REDIS_URL="redis://localhost:6379"

# For running inside Docker containers (resolved via Docker bridge DNS):
DATABASE_URL="postgresql://postgres:postgrespassword@db:5432/cerevia?schema=public"
REDIS_URL="redis://redis:6379"

# ------------------------------------------------------------------------------
# 4. Authentication Security
# ------------------------------------------------------------------------------
# Secret key used to sign and verify JSON Web Tokens (JWT) for authentication.
# Generate a secure random string in production (e.g. using `openssl rand -base64 32`).
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
