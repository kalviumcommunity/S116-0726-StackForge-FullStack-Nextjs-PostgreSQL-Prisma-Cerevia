# ==============================================================================
# Cerevia — Environment Variables Template
# Duplicate this file as '.env' or '.env.local' and supply local credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Local Application Configuration
# ------------------------------------------------------------------------------
PORT=3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# 2. Database & Redis Credentials (used by Docker Compose & local connection)
# ------------------------------------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgrespassword
DB_NAME=cerevia
DB_PORT=5432
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# 3. Connection URLs
# ------------------------------------------------------------------------------
# For local development outside of Docker (default):
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/cerevia?schema=public"
REDIS_URL="redis://localhost:6379"

# For running inside Docker containers (resolved via Docker bridge DNS):
# DATABASE_URL="postgresql://postgres:postgrespassword@db:5432/cerevia?schema=public"
# REDIS_URL="redis://redis:6379"

# ------------------------------------------------------------------------------
# 4. Authentication Security
# ------------------------------------------------------------------------------
# Secret key used to sign and verify JSON Web Tokens (JWT) for authentication.
# Generate a secure random string in production (e.g. using `openssl rand -base64 32`).
JWT_SECRET="Cerevia@2026$Backend#Production!JWTSecret123456789"
# Comma-separated list of allowed origins for Cross-Origin Resource Sharing (CORS).
# Defaults to "http://localhost:3000" if not provided.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ------------------------------------------------------------------------------
# 5. Leaderboard & Cache Configurations
# ------------------------------------------------------------------------------
# Time-To-Live (TTL) in seconds for weekly leaderboard caches in Redis.
# Defaults to 3600 (1 hour) if not specified.
LEADERBOARD_CACHE_TTL=3600

# ------------------------------------------------------------------------------
# 6. Background Task / Cron Job Schedules
# ------------------------------------------------------------------------------
# Cron schedule for the hourly pre-calculation and caching of leaderboards.
# Defaults to "0 * * * *" (every hour at minute 0).
LEADERBOARD_REFRESH_CRON="0 * * * *"

# Cron schedule for the daily streak resetting job to clean up inactive users.
# Defaults to "0 0 * * *" (every day at midnight UTC).
STREAK_VERIFICATION_CRON="0 0 * * *"
