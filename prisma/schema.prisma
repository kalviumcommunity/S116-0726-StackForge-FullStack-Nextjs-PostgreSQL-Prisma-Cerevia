// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  password  String
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Streak & XP tracking fields
  currentStreak  Int       @default(0)
  maxStreak      Int       @default(0)
  totalXP        Int       @default(0)
  currentXP      Int       @default(0)
  lastActivityAt DateTime?

  // Relations
  lessonProgress     LessonProgress[]
  achievements       UserAchievement[]
  leaderboardEntries Leaderboard[]
  xpHistory          XPHistory[]
}

model Lesson {
  id          String           @id @default(uuid())
  title       String
  description String?
  xpReward    Int              @default(10)
  difficulty  String // e.g. "Beginner", "Intermediate", "Advanced"
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  progress    LessonProgress[]
  xpHistory   XPHistory[]
}

model LessonProgress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Leaderboard {
  id        String   @id @default(uuid())
  userId    String
  score     Int // Accumulated score/points for the week
  rank      Int // User rank in the current hourly snapshot
  week      Int // Week number of the year
  year      Int // Year of the leaderboard
  updatedAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, week, year])
  @@index([rank])
  @@index([week, year])
}

model Achievement {
  id          String            @id @default(uuid())
  title       String            @unique
  description String
  badgeIcon   String // badge image / identifier
  xpReward    Int               @default(0)
  createdAt   DateTime          @default(now())
  users       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model XPHistory {
  id        String   @id @default(uuid())
  userId    String
  lessonId  String?
  xpEarned  Int
  reason    String // e.g. "LESSON_COMPLETION", "DAILY_STREAK", "ACHIEVEMENT"
  timestamp DateTime @default(now())

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([lessonId])
}
